FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0.0026374000000000002;

boundaryField
{
    inlet
    {
        type            calculated;
        value           $internalField;
    }

    outlet
    {
	    type		    calculated;
	    value		    $internalField;
    }

    "(symmetryTop|symmetryBot)"
    {
        type        symmetryPlane;
    }
    
    frontAndBack
    {
        type            empty;
    }

    walls
    {
        type            nutkWallFunction;
        value           $internalField;
    }
}
