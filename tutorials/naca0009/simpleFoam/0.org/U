FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (131.87 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }
    
    outlet
    {
        type            zeroGradient;
    }

    "(symmetryTop|symmetryBot)"
    {
        type        symmetryPlane;
    }
    
    frontAndBack
    {
        type            empty;
    }

    walls
    {
        type            noSlip;
    }
}

